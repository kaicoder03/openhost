{
  "description": "openhost wire-framing test vectors. Every implementation MUST pass all of these to claim v1 conformance.",
  "version": "openhost1",
  "encoding_notes": [
    "All byte strings are hex-encoded.",
    "The wire format is: type (1 byte) | length (4 bytes little-endian) | payload (length bytes).",
    "Implementations MUST accept partial inputs (return 'need more bytes') and MUST reject malformed inputs (unknown type, oversized length, non-empty payload for marker types)."
  ],
  "constants": {
    "FRAME_HEADER_LEN": 5,
    "MAX_PAYLOAD_LEN": 16777215
  },
  "frame_types": {
    "REQUEST_HEAD": 1,
    "REQUEST_BODY": 2,
    "REQUEST_END": 3,
    "RESPONSE_HEAD": 17,
    "RESPONSE_BODY": 18,
    "RESPONSE_END": 19,
    "WS_UPGRADE": 32,
    "WS_FRAME": 33,
    "AUTH_NONCE": 48,
    "AUTH_CLIENT": 49,
    "AUTH_HOST": 50,
    "ERROR": 240,
    "PING": 254,
    "PONG": 255
  },
  "encode_roundtrip": [
    {
      "name": "empty_ping",
      "frame_type": "PING",
      "payload_hex": "",
      "encoded_hex": "fe00000000"
    },
    {
      "name": "empty_pong",
      "frame_type": "PONG",
      "payload_hex": "",
      "encoded_hex": "ff00000000"
    },
    {
      "name": "empty_request_end",
      "frame_type": "REQUEST_END",
      "payload_hex": "",
      "encoded_hex": "0300000000"
    },
    {
      "name": "request_head_short",
      "frame_type": "REQUEST_HEAD",
      "payload_ascii": "GET / HTTP/1.1\r\nHost: example\r\n\r\n",
      "payload_hex": "474554202f20485454502f312e310d0a486f73743a206578616d706c650d0a0d0a",
      "encoded_hex": "0121000000474554202f20485454502f312e310d0a486f73743a206578616d706c650d0a0d0a"
    },
    {
      "name": "response_body_255_bytes",
      "frame_type": "RESPONSE_BODY",
      "payload_repeat_byte": "a5",
      "payload_length": 255,
      "encoded_header_hex": "12ff000000"
    },
    {
      "name": "error_utf8",
      "frame_type": "ERROR",
      "payload_ascii": "upstream-unreachable",
      "payload_hex": "757073747265616d2d756e726561636861626c65",
      "encoded_hex": "f014000000757073747265616d2d756e726561636861626c65"
    },
    {
      "name": "auth_nonce_32_bytes",
      "frame_type": "AUTH_NONCE",
      "payload_hex": "00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff",
      "encoded_hex": "302000000000112233445566778899aabbccddeeff00112233445566778899aabbccddeeff"
    },
    {
      "name": "auth_client_client_pk_plus_sig",
      "frame_type": "AUTH_CLIENT",
      "note": "32-byte client_pk followed by 64-byte Ed25519 sig_client",
      "payload_hex": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaabbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
      "encoded_hex": "3160000000aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaabbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
    },
    {
      "name": "auth_host_sig",
      "frame_type": "AUTH_HOST",
      "note": "64-byte Ed25519 sig_host",
      "payload_hex": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
      "encoded_hex": "3240000000cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
    }
  ],
  "reject": [
    {
      "name": "unknown_type_code",
      "encoded_hex": "0000000000",
      "expect": "MalformedFrame: unknown type code"
    },
    {
      "name": "oversized_length",
      "encoded_hex": "1200000001",
      "expect": "OversizedFrame: requested length 16777216 exceeds limit 16777215"
    },
    {
      "name": "ping_with_body_forbidden",
      "encoded_hex": "fe03000000000000",
      "expect": "MalformedFrame: frame type forbids payload but length is non-zero"
    },
    {
      "name": "request_end_with_body_forbidden",
      "encoded_hex": "0301000000ff",
      "expect": "MalformedFrame: frame type forbids payload but length is non-zero"
    }
  ],
  "partial": [
    {
      "name": "header_incomplete",
      "encoded_hex": "0100",
      "expect": "need more bytes"
    },
    {
      "name": "payload_incomplete",
      "encoded_hex": "010a00000068656c6c",
      "expect": "need more bytes",
      "note": "REQUEST_HEAD claims 10 payload bytes but only 4 are present"
    }
  ]
}
