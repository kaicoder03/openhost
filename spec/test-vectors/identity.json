{
  "description": "openhost identity test vectors. Every implementation MUST pass all of these to claim v1 conformance.",
  "version": "openhost1",
  "encoding_notes": [
    "All byte strings are hex-encoded.",
    "The z-base-32 alphabet is: ybndrfg8ejkmcpqxot1uwisza345h769.",
    "A 256-bit (32-byte) key encodes to exactly 52 z-base-32 characters."
  ],
  "vectors": [
    {
      "name": "rfc8032_test_vector_1",
      "source": "RFC 8032 §7.1 Ed25519 Test Vector #1",
      "signing_seed_hex": "9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60",
      "public_key_hex": "d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a",
      "public_key_zbase32": "47pjoycnsrfmxikm95jh13y88e8qnhzu5kungjpxyepgt7a8krpy",
      "message_hex": "",
      "signature_hex": "e5564300c360ac729086e2cc806e828a84877f1eb8e5d974d873e065224901555fb8821590a33bacc61e39701cf9b46bd25bf5f0595bbe24655141438e7a100b"
    },
    {
      "name": "rfc8032_test_vector_2",
      "source": "RFC 8032 §7.1 Ed25519 Test Vector #2",
      "signing_seed_hex": "4ccd089b28ff96da9db6c346ec114e0f5b8a319f35aba624da8cf6ed4fb8a6fb",
      "public_key_hex": "3d4017c3e843895a92b70aa74d1b7ebc9c982ccf2ec4968cc0cd55f12af4660c",
      "public_key_zbase32": "8iybxo9eeqriirizbkuw4g56z1qjomgxf5njpdgy3ik9nkzwcagy",
      "message_hex": "72",
      "signature_hex": "92a009a9f0d4cab8720e820b5f642540a2b27b5416503f8fb3762223ebdb69da085ac1e43e15996e458f3613d0f11d8c387b2eaeb4302aeeb00d291612bb0c00"
    },
    {
      "name": "openhost_url_no_path",
      "public_key_zbase32": "47pjoycnsrfmxikm95jh13y88e8qnhzu5kungjpxyepgt7a8krpy",
      "url_input": "oh://47pjoycnsrfmxikm95jh13y88e8qnhzu5kungjpxyepgt7a8krpy",
      "url_normalized": "oh://47pjoycnsrfmxikm95jh13y88e8qnhzu5kungjpxyepgt7a8krpy/",
      "expected_path": "/"
    },
    {
      "name": "openhost_url_with_path",
      "public_key_zbase32": "47pjoycnsrfmxikm95jh13y88e8qnhzu5kungjpxyepgt7a8krpy",
      "url_input": "oh://47pjoycnsrfmxikm95jh13y88e8qnhzu5kungjpxyepgt7a8krpy/library/items/42",
      "url_normalized": "oh://47pjoycnsrfmxikm95jh13y88e8qnhzu5kungjpxyepgt7a8krpy/library/items/42",
      "expected_path": "/library/items/42"
    }
  ],
  "negative_vectors": [
    {
      "name": "zbase32_wrong_length",
      "public_key_zbase32": "tooshort",
      "expect": "error: public key z-base-32 must be exactly 52 characters"
    },
    {
      "name": "zbase32_non_alphabet_char",
      "public_key_zbase32": "||||||||||||||||||||||||||||||||||||||||||||||||||||",
      "expect": "error: z-base-32 public key contains invalid characters"
    },
    {
      "name": "url_missing_scheme",
      "url_input": "https://47pjoycnsrfmxikm95jh13y88e8qnhzu5kungjpxyepgt7a8krpy/",
      "expect": "error: missing oh:// scheme"
    },
    {
      "name": "url_rejects_query",
      "url_input": "oh://47pjoycnsrfmxikm95jh13y88e8qnhzu5kungjpxyepgt7a8krpy/?x=1",
      "expect": "error: openhost URLs must not carry query or fragment components"
    },
    {
      "name": "url_rejects_fragment",
      "url_input": "oh://47pjoycnsrfmxikm95jh13y88e8qnhzu5kungjpxyepgt7a8krpy/#top",
      "expect": "error: openhost URLs must not carry query or fragment components"
    }
  ]
}
