---
interface Props {
  title: string;
  body: string;
  icon: "shield" | "lock" | "key";
}
const { title, body, icon } = Astro.props;
---

<article
  class="group relative flex h-full flex-col gap-4 rounded-2xl border border-[var(--color-gray-800)] bg-[var(--color-gray-900)]/70 p-6 transition hover:border-[var(--color-accent-700)]"
>
  <div
    class="flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--color-accent-950)] text-[var(--color-accent-400)]"
  >
    {icon === "shield" && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
        <path d="M12 3l8 3v6c0 4.5-3.2 8.5-8 9-4.8-.5-8-4.5-8-9V6l8-3z"/>
      </svg>
    )}
    {icon === "lock" && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
        <rect x="4.5" y="10.5" width="15" height="10" rx="2"/>
        <path d="M8 10.5V7a4 4 0 1 1 8 0v3.5"/>
      </svg>
    )}
    {icon === "key" && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
        <circle cx="8.5" cy="15.5" r="4"/>
        <path d="M11.5 12.5l8-8M16 5l3 3M14.5 6.5L17 9"/>
      </svg>
    )}
  </div>
  <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold leading-tight text-[var(--color-gray-50)]">
    {title}
  </h3>
  <p class="text-sm leading-relaxed text-[var(--color-gray-300)]">{body}</p>
</article>
