---
import NetworkDiagram from "./NetworkDiagram.astro";
---

<section
  class="relative mx-auto flex w-full max-w-6xl flex-col items-center gap-12 px-6 pt-20 pb-10 text-center sm:pt-28 md:pt-36"
>
  <span
    class="inline-flex items-center gap-2 rounded-full border border-[var(--color-gray-800)] bg-[var(--color-gray-900)]/70 px-3 py-1 text-xs font-medium tracking-wide text-[var(--color-gray-400)] uppercase backdrop-blur"
  >
    <span class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-signal-500)]"></span>
    self-host · unreachable no more
  </span>

  <h1
    class="max-w-3xl text-balance font-[family-name:var(--font-display)] text-5xl font-semibold leading-[1.05] tracking-tight text-[var(--color-gray-50)] sm:text-6xl md:text-7xl"
  >
    Your home server. Reachable.
    <span class="block text-[var(--color-gray-400)]">Nothing else in between.</span>
  </h1>

  <p
    class="max-w-2xl text-pretty text-base leading-relaxed text-[var(--color-gray-300)] sm:text-lg"
  >
    openhost connects your phone to services running on your own machines — over
    end-to-end encrypted WebRTC, addressed by a public key, discovered on the
    BitTorrent DHT. No port forwarding. No tunnel service. No account.
  </p>

  <div class="flex flex-wrap items-center justify-center gap-3">
    <a
      href={import.meta.env.BASE_URL + "spec/00-overview/"}
      class="inline-flex items-center gap-2 rounded-lg bg-[var(--color-accent-500)] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[var(--color-accent-400)] focus-visible:ring-2 focus-visible:ring-[var(--color-accent-300)] focus-visible:outline-none"
    >
      Read the spec
      <svg
        viewBox="0 0 20 20"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-4 w-4"
        aria-hidden="true"
      >
        <path d="M7 5l5 5-5 5" />
      </svg>
    </a>

    <span
      class="inline-flex cursor-not-allowed items-center gap-2 rounded-lg border border-[var(--color-gray-800)] bg-[var(--color-gray-900)] px-5 py-3 text-sm font-semibold text-[var(--color-gray-400)]"
      title="Installation instructions will appear here at M9."
    >
      Install
      <span class="text-[var(--color-gray-500)]">— coming soon</span>
    </span>
  </div>

  <div class="w-full pt-4">
    <NetworkDiagram />
  </div>
</section>
